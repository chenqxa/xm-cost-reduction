# 环境配置示例文件
# 复制此文件为 .env 并填入实际值

# Node 环境 (development | production)
NODE_ENV=development

# SQL Server 数据库配置
# 格式: Server=服务器地址,端口;Database=数据库名;User Id=用户名;Password=密码;
XM_SQLSERVER_CONNECTION_STRING=Server=localhost,1433;Database=ProjectDB;User Id=sa;Password=YourPassword;
XM_SQLSERVER_TABLE=ICBom
XM_SQLSERVER_FORMS_LIMIT=50

# 可选: 使用上游 API 作为数据源
# XM_FORMS_API_URL=https://api.example.com/forms
# XM_FORMS_API_KEY=your_api_key_here

# 或者使用这些别名
# FORMS_DB_API_URL=https://api.example.com/forms
# FORMS_DB_API_KEY=your_api_key_here
